# ═══════════════════════════════════════════════════════════════
# VILLA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com valores reais
# NUNCA comite o arquivo .env no Git
# ═══════════════════════════════════════════════════════════════

# ── Ambiente ──
ENVIRONMENT=development  # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ── FastAPI ──
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2
ALLOWED_ORIGINS=http://localhost:3000,https://villa.seudominio.com.br

# ── PostgreSQL ──
POSTGRES_USER=villa
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE_AQUI
POSTGRES_DB=villa_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ── Anthropic (Claude API) ──
ANTHROPIC_API_KEY=sk-ant-TROCAR_AQUI
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-20250514
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.3

# ── Kommo CRM ──
KOMMO_API_TOKEN=TROCAR_AQUI
KOMMO_ACCOUNT_URL=https://SUACONTA.kommo.com
KOMMO_WEBHOOK_SECRET=TROCAR_AQUI

# ── Meta Ads ──
META_ACCESS_TOKEN=TROCAR_AQUI
META_APP_SECRET=TROCAR_AQUI
META_AD_ACCOUNT_IDS=act_123456789,act_987654321
META_PIXEL_ID=TROCAR_AQUI
META_CAPI_TOKEN=TROCAR_AQUI

# ── WhatsApp Business API ──
WHATSAPP_TOKEN=TROCAR_AQUI
WHATSAPP_PHONE_ID=TROCAR_AQUI
WHATSAPP_VERIFY_TOKEN=TROCAR_AQUI
WHATSAPP_WEBHOOK_SECRET=TROCAR_AQUI

# ── Google (Service Account) ──
GOOGLE_SERVICE_ACCOUNT_JSON=config/google_service_account.json
GOOGLE_ADS_SCRIPT_URL=https://script.google.com/macros/s/TROCAR_AQUI/exec

# ── InLead ──
INLEAD_WEBHOOK_SECRET=TROCAR_AQUI

# ── N8N ──
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=TROCAR_AQUI

# ── Segurança ──
JWT_SECRET_KEY=TROCAR_CHAVE_JWT_FORTE_AQUI
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
ENCRYPTION_KEY=TROCAR_CHAVE_FERNET_AQUI

# ── Scheduler ──
DAILY_ROUTINE_HOUR=7
DAILY_ROUTINE_MINUTE=0
WEEKLY_REPORT_DAY=fri
WEEKLY_REPORT_HOUR=8
MONITOR_INTERVAL_MINUTES=30

# ── Backup ──
BACKUP_DIR=/opt/villa/data/backups
BACKUP_RETENTION_DAYS=30
